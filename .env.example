# Copy to .env and fill in your PAPER keys from https://app.alpaca.markets/paper/dashboard/overview
# Paper and live use DIFFERENT keys and base URLs. Keep ALPACA_PAPER=true until you have
# run on paper for at least ~2 weeks.

APCA_API_KEY_ID=your_paper_key_id
APCA_API_SECRET_KEY=your_paper_secret_key

# true = paper trading (paper-api.alpaca.markets), false = LIVE money. Default true.
ALPACA_PAPER=true

# Market-data feed for historical bars: 'sip' (recommended) or 'iex'.
#   sip = full market -> accurate 50/200 SMAs; FREE on Basic for data >=15min old (the bot's
#         16-min end clamp guarantees this). NOTE: 'delayed_sip' is NOT accepted by the bars
#         endpoint. Real-time SIP trades are paid-only, so the live marketable-limit price
#         anchor automatically falls back to real-time IEX (free) -> slippage cap still works.
#   iex = free, real-time, but only ~3% of volume (thin bars; SMAs computed off sparse data).
ALPACA_FEED=sip

# JSON array of symbols to trade (e.g. ["SPY","QQQ"]). Comma-separated is NOT supported.
BOT_SYMBOLS=["SPY","QQQ","XLK","XLF","XLE","XLV","XLP","XLU","XLY","IWM"]

# Bar timeframe for signals: 1Day, 1Hour, 15Min, etc.
BOT_TIMEFRAME=1Day

# Strategy: trend_momentum (validated default) or stoch_rsi_mfi (retired mean-reversion)
BOT_STRATEGY=trend_momentum

# Market-regime gate: block new longs when SPY < its 200-day SMA (conservative). Default true.
BOT_MARKET_REGIME_FILTER=true
# Inverse-vol position sizing (validate before enabling): false=fixed-fraction.
BOT_VOL_TARGETING=false
BOT_VOL_TARGET_PCT=0.02
# Trend: enter an in-progress uptrend on startup, not only on a fresh golden cross (validate first).
BOT_TREND_ENTER_ON_REGIME=false
# Allow fractional shares so high-priced symbols are tradeable on a small account (else
# whole-share sizing floors to 0 and the symbol silently never trades).
BOT_ALLOW_FRACTIONAL=false
# Trailing peak-to-trough kill switch (0 = off): halt when equity falls this far below its
# high-water mark, on top of the daily/weekly/monthly stops. e.g. 0.15 = 15%.
BOT_MAX_DRAWDOWN_PCT=0.0

# Ledger + heartbeat paths. Set these to ABSOLUTE paths if the watchdog runs as a separate
# process/container so both point at the exact same files (a relative path resolves per-CWD).
# BOT_LEDGER_PATH=/abs/path/data/ledger.sqlite
# BOT_HEARTBEAT_PATH=/abs/path/data/heartbeat.json

# --- Alerting (all optional; unset = log-only) ---
# Slack incoming webhook URL for kill-switch / reject / error / watchdog alerts
ALERT_SLACK_WEBHOOK=
# Or email via SMTP
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
